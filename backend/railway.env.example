# FleetOpt — paste into Railway → fleetops service → Variables → Raw Editor
#
# DATABASE_URL: use "Add Reference" → MySQL → MYSQL_URL (recommended), or paste internal MYSQL_URL.
# Do NOT use MYSQL_PUBLIC_URL for backend-to-MySQL inside Railway.
#
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"

APP_ENV=production
SECRET_KEY=REPLACE_WITH_32_PLUS_CHAR_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=${{MySQL.MYSQL_URL}}
FRONTEND_URL=https://fleetopsservices.netlify.app
CORS_ORIGINS=https://fleetopsservices.netlify.app
UPLOADS_ROOT=/app/uploads
# IMPORTANT: Mount a Railway Volume at /app/uploads so helper proof images survive redeploys.
# Without a volume, files are lost on restart while DB still stores helper_proofs/... paths (404).
USE_CLERK_AUTH=false
DIESEL_PRICE_PHP_PER_LITER=74.75
TOLL_FEES_PHP_PER_TRIP=0

# Email (Contact Support → admin Gmail).
# IMPORTANT: EMAIL_FROM must use a domain verified in Resend (Dashboard → Domains).
# This project has deliverexapp.com verified — do NOT use unverified @fleetopt.com.
RESEND_API_KEY=
EMAIL_FROM=FleetOpt <noreply@deliverexapp.com>
FEEDBACK_INBOX_EMAIL=
