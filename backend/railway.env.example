# FleetOpt — paste into Railway → fleetops service → Variables → Raw Editor
#
# DATABASE_URL: use "Add Reference" → MySQL → MYSQL_URL (recommended), or paste internal MYSQL_URL.
# Do NOT use MYSQL_PUBLIC_URL for backend-to-MySQL inside Railway.
#
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"

APP_ENV=production
SECRET_KEY=REPLACE_WITH_32_PLUS_CHAR_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=${{MySQL.MYSQL_URL}}
FRONTEND_URL=https://fleetops-ih16smrhx-fleetopsservices-8189s-projects.vercel.app
CORS_ORIGINS=https://fleetops-ih16smrhx-fleetopsservices-8189s-projects.vercel.app
UPLOADS_ROOT=/app/uploads
USE_CLERK_AUTH=false
DIESEL_PRICE_PHP_PER_LITER=74.75
TOLL_FEES_PHP_PER_TRIP=0
