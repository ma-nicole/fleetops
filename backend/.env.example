# FleetOpt Backend Environment Variables
# Copy this file to .env and update values for your environment

# App Configuration
APP_NAME=FleetOpt API
APP_ENV=production
SECRET_KEY=change-me-to-a-strong-secret-key-32-chars-min

# Database Configuration (Local PostgreSQL)
USE_CLOUD_SQL=false
DATABASE_URL=postgresql+psycopg://fleetopt:fleetopt@localhost:5432/fleetopt

# Google Cloud SQL Configuration (when USE_CLOUD_SQL=true)
GCP_PROJECT_ID=your-gcp-project-id
CLOUD_SQL_INSTANCE=your-project:region:instance-name
CLOUD_SQL_DB_USER=fleetopt
CLOUD_SQL_DB_PASSWORD=your-strong-password
CLOUD_SQL_DB_NAME=fleetopt

# Frontend URL
FRONTEND_URL=https://yourdomain.com

# Clerk Authentication
USE_CLERK_AUTH=false
CLERK_API_KEY=your_clerk_api_key_here
CLERK_FRONTEND_API=your_clerk_frontend_api_here

# Notifications (Resend)
RESEND_API_KEY=your_resend_api_key_here

# SMS (Twilio) - Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
