# ============================================
# FleetOpt Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to version control

# Application
APP_ENV=development
SECRET_KEY=your-super-secret-key-minimum-32-chars-generate-in-production

# Database Configuration
# Database connection (use PyMySQL). Example using host `db`:
DATABASE_URL=mysql+pymysql://fleetopt:fleetopt@localhost:3306/fleetopt

# JWT Token Expiration (in minutes, default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Clerk Authentication (Optional - leave blank if not using)
USE_CLERK_AUTH=false
CLERK_API_KEY=
CLERK_FRONTEND_API=

# Email Service (Resend)
RESEND_API_KEY=

# SMS Service (Twilio - Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
