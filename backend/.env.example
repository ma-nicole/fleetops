# ============================================================
# FleetOpt Backend — Environment Configuration
# ============================================================
# 1. Copy this file:   copy .env.example .env
# 2. Edit .env with your real values.
# ⚠️  NEVER commit .env to version control (it's in .gitignore).

# ── Application ────────────────────────────────────────────
APP_ENV=development

# Generate a strong key:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-key-change-in-production

JWT expiry in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MySQL / XAMPP ──────────────────────────────────────────
# XAMPP ships MySQL on port 3306 with root and NO password.
# Create the database in phpMyAdmin first:
#   CREATE DATABASE fleetopt CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# No password (XAMPP default):
DATABASE_URL=mysql+pymysql://root:@localhost:3306/fleetopt
#
# With a password (if you set one in XAMPP):
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/fleetopt

# ── Frontend URL (CORS) ────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Optional services (leave blank if not using) ───────────
USE_CLERK_AUTH=false
CLERK_API_KEY=
CLERK_FRONTEND_API=

RESEND_API_KEY=
EMAIL_FROM=FleetOpt <notifications@fleetopt.com>
# Customer feedback form emails (requires RESEND_API_KEY; use a verified domain in Resend). Example: fleetops@gmail.com
FEEDBACK_INBOX_EMAIL=
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Geocoding (booking route estimate) ────────────────────────
# Nominatim (OpenStreetMap) has NO API key and no billing — see:
#   https://nominatim.org/release-docs/latest/api/Search/
#   Usage policy: https://operations.osmfoundation.org/policies/nominatim/
# Backend FastAPI calls need a key that allows SERVER requests (IP restriction or none in dev).
# If your key is "HTTP referrers" only (for Maps in the browser), Geocoding/Directions from uvicorn FAIL
# → you get Nominatim + OSRM (~wrong km). Fix: create GOOGLE_MAPS_SERVER_API_KEY with IP restriction.
GOOGLE_MAPS_SERVER_API_KEY=
# Optional browser-oriented key (referrer); used only if SERVER key is empty.
GOOGLE_MAPS_GEOCODING_API_KEY=
# Optional dedicated Directions key; else falls back to SERVER then GEOCODING when GOOGLE_DIRECTIONS_…=true.
GOOGLE_MAPS_DIRECTIONS_API_KEY=
GOOGLE_DIRECTIONS_FALLBACK_TO_GEOCODING_KEY=true
USE_GOOGLE_DIRECTIONS_FOR_ROUTING=true
# Required for Nominatim: identify your app (contact URL or email), not a secret key:
GEOCODING_USER_AGENT=FleetOpt/1.0 (+https://your-domain.example/contact)
# Booking map preview (browser): NEXT_PUBLIC_GOOGLE_MAPS_API_KEY in frontend/.env.local, or /customer/maps-js-key.

# ── Road distance (after geocode) ─────────────────────────────────────────────
# Order: Google Directions (if key + Directions API enabled) → OpenRouteService → OSRM.
# For Google-aligned km: GOOGLE_MAPS_SERVER_API_KEY + Geocoding + Directions APIs; ORS/OSRM are fallbacks only.
# Truck-legal (OSM): OPENROUTESERVICE_API_KEY — backend uses driving-hgv by default when ORS is used.
USE_OSRM_DRIVING_DISTANCE=true
OSRM_ROUTE_BASE_URL=https://router.project-osrm.org
OSRM_ROUTE_PROFILE=driving
# true = OpenRouteService driving-hgv; false = driving-car (passenger).
USE_TRUCK_ROUTE_PROFILE=true
# Optional — https://openrouteservice.org/ (tried before OSRM when set)
OPENROUTESERVICE_API_KEY=

# Require real road km for bookings — no straight-line / guess fallback (Google / ORS / OSRM).
REQUIRE_ROUTED_DISTANCE=true

# ── Booking freight model — update diesel after weekly DOE oil bulletin (usually Tuesdays). ─────
DIESEL_PRICE_PHP_PER_LITER=74.75
TRUCK_FUEL_EFFICIENCY_KMPL=4.5
TRIP_WEAR_MISC_PHP_PER_KM=3.75
TRIP_DEPRECATION_RATE=0.10
HELPER_PAY_PHP_PER_TRIP=220
DRIVER_FREIGHT_COMMISSION_RATE=0.15
CARGO_WEIGHT_MULTIPLIER_PER_TON=0.07
