# ============================================================
# FleetOpt Backend — Environment Configuration
# ============================================================
# 1. Copy this file:   copy .env.example .env
# 2. Edit .env with your real values.
# ⚠️  NEVER commit .env to version control (it's in .gitignore).

# ── Application ────────────────────────────────────────────
APP_ENV=development

# Generate a strong key:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-key-change-in-production

JWT expiry in minutes (default 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MySQL / XAMPP ──────────────────────────────────────────
# XAMPP ships MySQL on port 3306 with root and NO password.
# Create the database in phpMyAdmin first:
#   CREATE DATABASE fleetopt CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# No password (XAMPP default):
DATABASE_URL=mysql+pymysql://root:@localhost:3306/fleetopt
#
# With a password (if you set one in XAMPP):
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/fleetopt

# ── Frontend URL (CORS) ────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Optional services (leave blank if not using) ───────────
USE_CLERK_AUTH=false
CLERK_API_KEY=
CLERK_FRONTEND_API=

RESEND_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
