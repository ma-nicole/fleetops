# FleetOpt Backend Environment
# Copy to `.env` and adjust values per environment.

# -------------------------------------------------------------------
# Development defaults
# -------------------------------------------------------------------
APP_ENV=development
SECRET_KEY=dev-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=mysql+pymysql://root:@localhost:3306/fleetopt
FRONTEND_URL=http://localhost:3000
UPLOADS_ROOT=uploads

# Optional CORS override (comma-separated).
# In production set only your approved HTTPS frontend domains.
# CORS_ORIGINS=https://fleetopsapp.xyz,https://www.fleetopsapp.xyz

# -------------------------------------------------------------------
# Production — fleetopsapp.xyz
# -------------------------------------------------------------------
# APP_ENV=production
# SECRET_KEY=replace-with-48-char-random-secret
# DATABASE_URL=mysql+pymysql://fleetopt:<db-password>@127.0.0.1:3306/fleetopt
# FRONTEND_URL=https://fleetopsapp.xyz
# CORS_ORIGINS=https://fleetopsapp.xyz,https://www.fleetopsapp.xyz
# UPLOADS_ROOT=/var/lib/fleetopt/uploads

# Optional integrations
USE_CLERK_AUTH=false
CLERK_API_KEY=
CLERK_FRONTEND_API=
CLERK_WEBHOOK_SECRET=

RESEND_API_KEY=
EMAIL_FROM=FleetOpt <notifications@fleetopt.com>
FEEDBACK_INBOX_EMAIL=
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Route estimation and distance services
GOOGLE_MAPS_GEOCODING_API_KEY=
GOOGLE_MAPS_DIRECTIONS_API_KEY=
GOOGLE_DIRECTIONS_FALLBACK_TO_GEOCODING_KEY=true
USE_GOOGLE_DIRECTIONS_FOR_ROUTING=true
GEOCODING_USER_AGENT=FleetOpt/1.0 (+https://fleetopsapp.xyz/contact)
OPENROUTESERVICE_API_KEY=
USE_TRUCK_ROUTE_PROFILE=true
OSRM_ROUTE_BASE_URL=https://router.project-osrm.org
OSRM_ROUTE_PROFILE=driving
USE_OSRM_DRIVING_DISTANCE=true
REQUIRE_ROUTED_DISTANCE=true

# Freight computation knobs used by backend settings
DIESEL_PRICE_PHP_PER_LITER=74.75
TOLL_FEES_PHP_PER_TRIP=0
