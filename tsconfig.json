{
  "extends": "./frontend/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./frontend",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "frontend/next-env.d.ts",
    "frontend/**/*.ts",
    "frontend/**/*.tsx",
    "frontend/.next/types/**/*.ts",
    "frontend/.next/dev/types/**/*.ts"
  ],
  "exclude": ["frontend/node_modules", "node_modules"]
}
