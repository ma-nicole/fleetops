# FleetOpt Frontend Environment
# Copy to `.env.local` and adjust values.

# -------------------------------------------------------------------
# Development defaults
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api-proxy
BACKEND_ORIGIN=http://127.0.0.1:8000

# -------------------------------------------------------------------
# Production — fleetopsapp.xyz (copy to `.env.local` before `npm run build` on VPS)
# -------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=https://fleetopsapp.xyz/api
# BACKEND_ORIGIN=http://127.0.0.1:8000

# Public pricing knobs (must stay aligned with backend settings if overridden)
NEXT_PUBLIC_DIESEL_PRICE_PHP_PER_LITER=74.75
NEXT_PUBLIC_TOLL_FEES_PHP_PER_TRIP=0

# Clerk (optional)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
