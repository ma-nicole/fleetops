# FleetOpt Frontend Environment Variables
# Copy this file to .env.local and update values for your environment

# API — pick ONE approach:

# A) Local dev (recommended): same-origin proxy so login/sign-up avoids "Failed to fetch".
#    Requires backend running (see README). Override host if FastAPI is not on 127.0.0.1:8000.
NEXT_PUBLIC_API_URL=/api-proxy
BACKEND_ORIGIN=http://127.0.0.1:8000

# B) Direct browser → API (needs CORS + reachable URL):
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Booking estimate fallback — keep aligned with backend `Settings` freight fields (diesel Tuesdays / PH pump price).
NEXT_PUBLIC_DIESEL_PRICE_PHP_PER_LITER=74.75
NEXT_PUBLIC_TRUCK_FUEL_KMPL=4.5
NEXT_PUBLIC_TRIP_WEAR_PHP_PER_KM=3.75
NEXT_PUBLIC_TRIP_DEPRECIATION_RATE=0.10
NEXT_PUBLIC_HELPER_PAY_PHP_PER_TRIP=220
NEXT_PUBLIC_DRIVER_FREIGHT_COMMISSION_RATE=0.15
NEXT_PUBLIC_CARGO_WEIGHT_MULT_PER_TON=0.07

# Clerk Configuration (optional)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Google Maps JavaScript API — optional browser key for route preview (or rely on backend GOOGLE_MAPS_GEOCODING_API_KEY via /customer/maps-js-key when signed in).
# If unset, the booking form fetches the server geocoding key (same GCP key must have “Maps JavaScript API” enabled; restrict by HTTP referrer).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Clerk instance URL (useful for custom domains)
# NEXT_PUBLIC_CLERK_INSTANCE_URL=https://your-custom-domain.clerk.accounts.com
